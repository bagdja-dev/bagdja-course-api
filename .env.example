PORT=3008
NODE_ENV=development

# Must match bagdja-auth JWT_SECRET
JWT_SECRET=your-secret-key-here

# Separate admin auth secret (do NOT reuse user JWT secret)
ADMIN_JWT_SECRET=your-admin-secret-key-here

# Supabase project URL + service role key (server-side only)
CLIENT_APP_ID="
CLIENT_APP_SECRET=""
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
