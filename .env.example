PORT=3008
NODE_ENV=development

# Protect Swagger UI at /docs (optional)
SWAGGER_USER=admin
SWAGGER_PASSWORD=change-me

# Must match bagdja-auth JWT_SECRET
JWT_SECRET=your-secret-key-here

# Separate admin auth secret (do NOT reuse user JWT secret)
ADMIN_JWT_SECRET=your-admin-secret-key-here

# Supabase project URL + service role key (server-side only)
CLIENT_APP_ID=""
CLIENT_APP_SECRET=""
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Midtrans Configuration
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SERVER_KEY=your-midtrans-server-key
MIDTRANS_CLIENT_KEY=your-midtrans-client-key
